digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_voting_ensemble [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await start_voting_ensemble(p)</i></td></tr><tr><td bgcolor="white" align="left">p['candidates'] = list(await asyncio.…'prompt'])))</td></tr></table>>];
  end_voting_ensemble [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await end_voting_ensemble(p)</i></td></tr></table>>];
  judge [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await judge(p)</i></td></tr></table>>];

  judge -> end_voting_ensemble;
  start_voting_ensemble -> judge;
}