digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_orchestrator_workers [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await start_orchestrator_workers(p)</i></td></tr><tr><td bgcolor="white" align="left">p['iteration'] = 0</td></tr><tr><td bgcolor="white" align="left">p['worker_results'] = []</td></tr></table>>];
  router_orchestrator_workers_line_65_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_orchestrator_workers_line_65_…(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p.get('next_action') == 'write'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_orchestrator_workers_line_63_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_orchestrator_workers_line_63_…(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p.get('next_action') == 'analyze'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_orchestrator_workers_line_68_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_orchestrator_workers_line_68_…(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['iteration'] &gt;= 10</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>pass</b></font></td></tr></table></td></tr></table>>];
  router_orchestrator_workers_line_61_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_orchestrator_workers_line_61_…(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p.get('next_action') == 'research'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_orchestrator_workers_line_58_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_orchestrator_workers_line_58_…(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p.get('is_complete')</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_orchestrator_workers_line_54_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_orchestrator_workers_line_54_…(p)</i></td></tr><tr><td bgcolor="white" align="left">p['iteration'] += 1</td></tr></table>>];
  router_orchestrator_workers_line_53_loop_back_0 [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_orchestrator_workers_line_53_…(p)</i></td></tr></table>>];
  end_orchestrator_workers [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await end_orchestrator_workers(p)</i></td></tr></table>>];
  analysis_worker [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await analysis_worker(p)</i></td></tr></table>>];
  data_worker [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await data_worker(p)</i></td></tr></table>>];
  orchestrator [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await orchestrator(p)</i></td></tr></table>>];
  synthesizer [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await synthesizer(p)</i></td></tr></table>>];
  writing_worker [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await writing_worker(p)</i></td></tr></table>>];

  analysis_worker -> router_orchestrator_workers_line_68_if;
  data_worker -> router_orchestrator_workers_line_68_if;
  orchestrator -> router_orchestrator_workers_line_58_if;
  router_orchestrator_workers_line_53_loop_back_0 -> router_orchestrator_workers_line_54_seq [constraint=false];
  router_orchestrator_workers_line_54_seq -> orchestrator;
  router_orchestrator_workers_line_58_if -> router_orchestrator_workers_line_61_if [label="F", color=indianred4];
  router_orchestrator_workers_line_58_if -> synthesizer [label="T", color=darkseagreen4];
  router_orchestrator_workers_line_61_if -> data_worker [label="T", color=darkseagreen4];
  router_orchestrator_workers_line_61_if -> router_orchestrator_workers_line_63_if [label="F", color=indianred4];
  router_orchestrator_workers_line_63_if -> analysis_worker [label="T", color=darkseagreen4];
  router_orchestrator_workers_line_63_if -> router_orchestrator_workers_line_65_if [label="F", color=indianred4];
  router_orchestrator_workers_line_65_if -> router_orchestrator_workers_line_68_if [label="F", color=indianred4];
  router_orchestrator_workers_line_65_if -> writing_worker [label="T", color=darkseagreen4];
  router_orchestrator_workers_line_68_if -> router_orchestrator_workers_line_53_loop_back_0 [label="F", color=indianred4];
  router_orchestrator_workers_line_68_if -> synthesizer [label="T", color=darkseagreen4];
  start_orchestrator_workers -> router_orchestrator_workers_line_53_loop_back_0;
  synthesizer -> end_orchestrator_workers;
  writing_worker -> router_orchestrator_workers_line_68_if;
}