digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_orchestrator_workers [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await start_orchestrator_workers(state)</i></td></tr><tr><td bgcolor="white" align="left">state['iteration'] = 0</td></tr></table>>];
  router_orchestrator_workers_line_67_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_orchestrator_workers_…(state)</i></td></tr><tr><td bgcolor="white" align="left">state['next_action'] = 'unknown'</td></tr></table>>];
  router_orchestrator_workers_line_63_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_orchestrator_workers_…(state)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> state.get('next_action') == 'write'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_orchestrator_workers_line_61_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_orchestrator_workers_…(state)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> state.get('next_action') == 'analyze'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_orchestrator_workers_line_71_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_orchestrator_workers_…(state)</i></td></tr><tr><td bgcolor="white" align="left">state['is_complete'] = True</td></tr></table>>];
  router_orchestrator_workers_line_70_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_orchestrator_workers_…(state)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> state['iteration'] &gt;= 10</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>pass</b></font></td></tr></table></td></tr></table>>];
  router_orchestrator_workers_line_59_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_orchestrator_workers_…(state)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> state.get('next_action') == 'research'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_orchestrator_workers_line_55_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_orchestrator_workers_…(state)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> state.get('is_complete')</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_orchestrator_workers_line_49_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_orchestrator_workers_…(state)</i></td></tr><tr><td bgcolor="white" align="left">state['iteration'] += 1</td></tr></table>>];
  router_orchestrator_workers_line_48_loop_back_0 [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_orchestrator_workers_…(state)</i></td></tr></table>>];
  end_orchestrator_workers [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await end_orchestrator_workers(state)</i></td></tr></table>>];
  analysis_worker [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await analysis_worker(state)</i></td></tr></table>>];
  data_worker [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await data_worker(state)</i></td></tr></table>>];
  orchestrator [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await orchestrator(state)</i></td></tr></table>>];
  synthesizer [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await synthesizer(state)</i></td></tr></table>>];
  writing_worker [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await writing_worker(state)</i></td></tr></table>>];

  analysis_worker -> router_orchestrator_workers_line_70_if;
  data_worker -> router_orchestrator_workers_line_70_if;
  orchestrator -> router_orchestrator_workers_line_55_if;
  router_orchestrator_workers_line_48_loop_back_0 -> router_orchestrator_workers_line_49_seq [constraint=false];
  router_orchestrator_workers_line_49_seq -> orchestrator;
  router_orchestrator_workers_line_55_if -> router_orchestrator_workers_line_59_if [label="F", color=indianred4];
  router_orchestrator_workers_line_55_if -> synthesizer [label="T", color=darkseagreen4];
  router_orchestrator_workers_line_59_if -> data_worker [label="T", color=darkseagreen4];
  router_orchestrator_workers_line_59_if -> router_orchestrator_workers_line_61_if [label="F", color=indianred4];
  router_orchestrator_workers_line_61_if -> analysis_worker [label="T", color=darkseagreen4];
  router_orchestrator_workers_line_61_if -> router_orchestrator_workers_line_63_if [label="F", color=indianred4];
  router_orchestrator_workers_line_63_if -> router_orchestrator_workers_line_67_seq [label="F", color=indianred4];
  router_orchestrator_workers_line_63_if -> writing_worker [label="T", color=darkseagreen4];
  router_orchestrator_workers_line_67_seq -> router_orchestrator_workers_line_70_if;
  router_orchestrator_workers_line_70_if -> router_orchestrator_workers_line_48_loop_back_0 [label="F", color=indianred4];
  router_orchestrator_workers_line_70_if -> router_orchestrator_workers_line_71_seq [label="T", color=darkseagreen4];
  router_orchestrator_workers_line_71_seq -> synthesizer;
  start_orchestrator_workers -> router_orchestrator_workers_line_48_loop_back_0;
  synthesizer -> end_orchestrator_workers;
  writing_worker -> router_orchestrator_workers_line_70_if;
}