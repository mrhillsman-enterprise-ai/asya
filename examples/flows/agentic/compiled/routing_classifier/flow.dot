digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_routing_classifier [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await start_routing_classifier(p)</i></td></tr></table>>];
  router_routing_classifier_line_47_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_routing_classifier_line_47_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p.get('category') == 'account'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_routing_classifier_line_45_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_routing_classifier_line_45_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p.get('category') == 'technical'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_routing_classifier_line_43_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_routing_classifier_line_43_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p.get('category') == 'billing'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  end_routing_classifier [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await end_routing_classifier(p)</i></td></tr></table>>];
  account_agent [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await account_agent(p)</i></td></tr></table>>];
  billing_agent [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await billing_agent(p)</i></td></tr></table>>];
  classifier [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await classifier(p)</i></td></tr></table>>];
  format_reply [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await format_reply(p)</i></td></tr></table>>];
  general_agent [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await general_agent(p)</i></td></tr></table>>];
  technical_agent [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await technical_agent(p)</i></td></tr></table>>];

  account_agent -> format_reply;
  billing_agent -> format_reply;
  classifier -> router_routing_classifier_line_43_if;
  format_reply -> end_routing_classifier;
  general_agent -> format_reply;
  router_routing_classifier_line_43_if -> billing_agent [label="T", color=darkseagreen4];
  router_routing_classifier_line_43_if -> router_routing_classifier_line_45_if [label="F", color=indianred4];
  router_routing_classifier_line_45_if -> router_routing_classifier_line_47_if [label="F", color=indianred4];
  router_routing_classifier_line_45_if -> technical_agent [label="T", color=darkseagreen4];
  router_routing_classifier_line_47_if -> account_agent [label="T", color=darkseagreen4];
  router_routing_classifier_line_47_if -> general_agent [label="F", color=indianred4];
  start_routing_classifier -> classifier;
  technical_agent -> format_reply;
}