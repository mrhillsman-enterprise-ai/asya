digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_human_in_the_loop [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await start_human_in_the_loop(p)</i></td></tr><tr><td bgcolor="white" align="left">p['attempt'] = 0</td></tr></table>>];
  router_human_in_the_loop_line_71_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_human_in_the_loop_line_71_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p.get('approval') == 'rejected'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_human_in_the_loop_line_76_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_human_in_the_loop_line_76_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['result'] = 'Max revision attempts reached'</td></tr></table>>];
  router_human_in_the_loop_line_75_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_human_in_the_loop_line_75_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['attempt'] &gt;= 3</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>pass</b></font></td></tr></table></td></tr></table>>];
  router_human_in_the_loop_line_66_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_human_in_the_loop_line_66_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p.get('approval') in ('approved', 'modified')</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_human_in_the_loop_line_57_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_human_in_the_loop_line_57_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['attempt'] += 1</td></tr></table>>];
  router_human_in_the_loop_line_56_loop_back_0 [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_human_in_the_loop_line_56_loo…(p)</i></td></tr></table>>];
  end_human_in_the_loop [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await end_human_in_the_loop(p)</i></td></tr></table>>];
  approval_gate [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await approval_gate(p)</i></td></tr></table>>];
  executor [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await executor(p)</i></td></tr></table>>];
  notifier [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await notifier(p)</i></td></tr></table>>];
  proposal_generator [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await proposal_generator(p)</i></td></tr></table>>];
  revision_agent [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await revision_agent(p)</i></td></tr></table>>];

  approval_gate -> router_human_in_the_loop_line_66_if;
  executor -> notifier;
  notifier -> end_human_in_the_loop;
  proposal_generator -> approval_gate;
  revision_agent -> router_human_in_the_loop_line_75_if;
  router_human_in_the_loop_line_56_loop_back_0 -> router_human_in_the_loop_line_57_seq [constraint=false];
  router_human_in_the_loop_line_57_seq -> proposal_generator;
  router_human_in_the_loop_line_66_if -> executor [label="T", color=darkseagreen4];
  router_human_in_the_loop_line_66_if -> router_human_in_the_loop_line_71_if [label="F", color=indianred4];
  router_human_in_the_loop_line_71_if -> revision_agent [label="T", color=darkseagreen4];
  router_human_in_the_loop_line_71_if -> router_human_in_the_loop_line_75_if [label="F", color=indianred4];
  router_human_in_the_loop_line_75_if -> router_human_in_the_loop_line_56_loop_back_0 [label="F", color=indianred4];
  router_human_in_the_loop_line_75_if -> router_human_in_the_loop_line_76_seq [label="T", color=darkseagreen4];
  router_human_in_the_loop_line_76_seq -> notifier;
  start_human_in_the_loop -> router_human_in_the_loop_line_56_loop_back_0;
}