digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_parallel_sectioning [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await start_parallel_sectioning(p)</i></td></tr></table>>];
  router_parallel_sectioning_line_44_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_parallel_sectioning_line_44_s…(p)</i></td></tr><tr><td bgcolor="white" align="left">p['analysis'] = list(await asyncio.ga…p['text'])))</td></tr></table>>];
  end_parallel_sectioning [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await end_parallel_sectioning(p)</i></td></tr></table>>];
  aggregator [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await aggregator(p)</i></td></tr></table>>];
  preprocessor [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await preprocessor(p)</i></td></tr></table>>];

  aggregator -> end_parallel_sectioning;
  preprocessor -> router_parallel_sectioning_line_44_seq;
  router_parallel_sectioning_line_44_seq -> aggregator;
  start_parallel_sectioning -> preprocessor;
}