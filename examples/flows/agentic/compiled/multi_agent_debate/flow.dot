digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_multi_agent_debate [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await start_multi_agent_debate(p)</i></td></tr><tr><td bgcolor="white" align="left">p['round'] = 0</td></tr><tr><td bgcolor="white" align="left">p['positions'] = list(await asyncio.g…uestion'])))</td></tr></table>>];
  router_multi_agent_debate_line_70_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_multi_agent_debate_line_70_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['positions'] = list(await asyncio.g…evise_c(p)))</td></tr></table>>];
  router_multi_agent_debate_line_67_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_multi_agent_debate_line_67_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['round'] &gt;= 3</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_multi_agent_debate_line_64_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_multi_agent_debate_line_64_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p.get('converged')</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_multi_agent_debate_line_60_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_multi_agent_debate_line_60_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['round'] += 1</td></tr></table>>];
  router_multi_agent_debate_line_59_loop_back_0 [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await router_multi_agent_debate_line_59_lo…(p)</i></td></tr></table>>];
  end_multi_agent_debate [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await end_multi_agent_debate(p)</i></td></tr></table>>];
  convergence_checker [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await convergence_checker(p)</i></td></tr></table>>];
  final_judge [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await final_judge(p)</i></td></tr></table>>];

  convergence_checker -> router_multi_agent_debate_line_64_if;
  final_judge -> end_multi_agent_debate;
  router_multi_agent_debate_line_59_loop_back_0 -> router_multi_agent_debate_line_60_seq [constraint=false];
  router_multi_agent_debate_line_60_seq -> convergence_checker;
  router_multi_agent_debate_line_64_if -> final_judge [label="T", color=darkseagreen4];
  router_multi_agent_debate_line_64_if -> router_multi_agent_debate_line_67_if [label="F", color=indianred4];
  router_multi_agent_debate_line_67_if -> final_judge [label="T", color=darkseagreen4];
  router_multi_agent_debate_line_67_if -> router_multi_agent_debate_line_70_seq [label="F", color=indianred4];
  router_multi_agent_debate_line_70_seq -> router_multi_agent_debate_line_59_loop_back_0;
  start_multi_agent_debate -> router_multi_agent_debate_line_59_loop_back_0;
}