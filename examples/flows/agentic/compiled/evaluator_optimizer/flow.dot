digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_evaluator_optimizer [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await start_evaluator_optimizer(state)</i></td></tr><tr><td bgcolor="white" align="left">state['iteration'] = 0</td></tr></table>>];
  router_evaluator_optimizer_line_68_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_evaluator_optimizer_l…(state)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> state['iteration'] &gt;= MAX_ITERATIONS</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>pass</b></font></td></tr></table></td></tr></table>>];
  router_evaluator_optimizer_line_64_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_evaluator_optimizer_l…(state)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> state.get('score', 0) &gt;= SCORE_THRESHOLD</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_evaluator_optimizer_line_55_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_evaluator_optimizer_l…(state)</i></td></tr><tr><td bgcolor="white" align="left">state['iteration'] += 1</td></tr></table>>];
  router_evaluator_optimizer_line_54_loop_back_0 [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_evaluator_optimizer_l…(state)</i></td></tr></table>>];
  end_evaluator_optimizer [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await end_evaluator_optimizer(state)</i></td></tr></table>>];
  evaluator [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await evaluator(state)</i></td></tr></table>>];
  generator [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await generator(state)</i></td></tr></table>>];
  polisher [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await polisher(state)</i></td></tr></table>>];

  evaluator -> router_evaluator_optimizer_line_64_if;
  generator -> evaluator;
  polisher -> end_evaluator_optimizer;
  router_evaluator_optimizer_line_54_loop_back_0 -> router_evaluator_optimizer_line_55_seq [constraint=false];
  router_evaluator_optimizer_line_55_seq -> generator;
  router_evaluator_optimizer_line_64_if -> polisher [label="T", color=darkseagreen4];
  router_evaluator_optimizer_line_64_if -> router_evaluator_optimizer_line_68_if [label="F", color=indianred4];
  router_evaluator_optimizer_line_68_if -> polisher [label="T", color=darkseagreen4];
  router_evaluator_optimizer_line_68_if -> router_evaluator_optimizer_line_54_loop_back_0 [label="F", color=indianred4];
  start_evaluator_optimizer -> router_evaluator_optimizer_line_54_loop_back_0;
}