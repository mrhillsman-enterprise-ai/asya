digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_sequential_pipeline [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await start_sequential_pipeline(p)</i></td></tr></table>>];
  end_sequential_pipeline [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await end_sequential_pipeline(p)</i></td></tr></table>>];
  data_analyst [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await data_analyst(p)</i></td></tr></table>>];
  execution_planner [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await execution_planner(p)</i></td></tr></table>>];
  risk_evaluator [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await risk_evaluator(p)</i></td></tr></table>>];
  trading_analyst [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = await trading_analyst(p)</i></td></tr></table>>];

  data_analyst -> trading_analyst;
  execution_planner -> risk_evaluator;
  risk_evaluator -> end_sequential_pipeline;
  start_sequential_pipeline -> data_analyst;
  trading_analyst -> execution_planner;
}