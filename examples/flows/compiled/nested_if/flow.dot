digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_nested_if_flow [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_nested_if_flow(p)</i></td></tr></table>>];
  router_nested_if_flow_line_13_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_nested_if_flow_line_13_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['l2'] = 'X'</td></tr></table>>];
  router_nested_if_flow_line_16_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_nested_if_flow_line_16_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['l2'] = 'Y'</td></tr></table>>];
  router_nested_if_flow_line_12_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_nested_if_flow_line_12_if(p)</i></td></tr><tr><td bgcolor="white" align="left">p['l1'] = 'A'</td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['level2'] == 'X'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_nested_if_flow_line_21_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_nested_if_flow_line_21_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['l2'] = 'X'</td></tr></table>>];
  router_nested_if_flow_line_24_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_nested_if_flow_line_24_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['l2'] = 'Y'</td></tr></table>>];
  router_nested_if_flow_line_20_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_nested_if_flow_line_20_if(p)</i></td></tr><tr><td bgcolor="white" align="left">p['l1'] = 'B'</td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['level2'] == 'X'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_nested_if_flow_line_10_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_nested_if_flow_line_10_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['level1'] == 'A'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  end_nested_if_flow [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_nested_if_flow(p)</i></td></tr></table>>];
  handler_a_x [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_a_x(p)</i></td></tr></table>>];
  handler_a_y [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_a_y(p)</i></td></tr></table>>];
  handler_b_x [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_b_x(p)</i></td></tr></table>>];
  handler_b_y [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_b_y(p)</i></td></tr></table>>];
  handler_finalize [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_finalize(p)</i></td></tr></table>>];
  handler_validate [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_validate(p)</i></td></tr></table>>];

  handler_a_x -> handler_finalize;
  handler_a_y -> handler_finalize;
  handler_b_x -> handler_finalize;
  handler_b_y -> handler_finalize;
  handler_finalize -> end_nested_if_flow;
  handler_validate -> router_nested_if_flow_line_10_if;
  router_nested_if_flow_line_10_if -> router_nested_if_flow_line_12_if [label="T", color=darkseagreen4];
  router_nested_if_flow_line_10_if -> router_nested_if_flow_line_20_if [label="F", color=indianred4];
  router_nested_if_flow_line_12_if -> router_nested_if_flow_line_13_seq [label="T", color=darkseagreen4];
  router_nested_if_flow_line_12_if -> router_nested_if_flow_line_16_seq [label="F", color=indianred4];
  router_nested_if_flow_line_13_seq -> handler_a_x;
  router_nested_if_flow_line_16_seq -> handler_a_y;
  router_nested_if_flow_line_20_if -> router_nested_if_flow_line_21_seq [label="T", color=darkseagreen4];
  router_nested_if_flow_line_20_if -> router_nested_if_flow_line_24_seq [label="F", color=indianred4];
  router_nested_if_flow_line_21_seq -> handler_b_x;
  router_nested_if_flow_line_24_seq -> handler_b_y;
  start_nested_if_flow -> handler_validate;
}