digraph flow {
  rankdir=TB;
  compound=true;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_data_pipeline [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_data_pipeline(p)</i></td></tr></table>>];
  router_data_pipeline_line_6_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_data_pipeline_line_6_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['error_type'] = 'validation'</td></tr></table>>];
  router_data_pipeline_line_9_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_data_pipeline_line_9_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['error_type'] = 'type_mismatch'</td></tr></table>>];
  router_data_pipeline_line_12_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_data_pipeline_line_12_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['error_type'] = 'runtime'</td></tr></table>>];
  end_data_pipeline [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_data_pipeline(p)</i></td></tr></table>>];
  handle_runtime_error [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handle_runtime_error(p)</i></td></tr></table>>];
  handle_type_error [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handle_type_error(p)</i></td></tr></table>>];
  handle_validation_error [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handle_validation_error(p)</i></td></tr></table>>];
  subgraph cluster_try_0 {
    style=dashed;
    color="snow4";
    fontname="Courier";
    fontsize=10;
    label="try";
    parse_input [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = parse_input(p)</i></td></tr></table>>];
    transform_data [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = transform_data(p)</i></td></tr></table>>];
  }

  handle_runtime_error -> end_data_pipeline;
  handle_type_error -> end_data_pipeline;
  handle_validation_error -> end_data_pipeline;
  parse_input -> transform_data;
  router_data_pipeline_line_12_seq -> handle_runtime_error;
  router_data_pipeline_line_6_seq -> handle_validation_error;
  router_data_pipeline_line_9_seq -> handle_type_error;
  start_data_pipeline -> parse_input;
  transform_data -> end_data_pipeline;
  transform_data -> router_data_pipeline_line_12_seq [ltail=cluster_try_0, color=snow4, style=dashed, label="except RuntimeError"];
  transform_data -> router_data_pipeline_line_6_seq [ltail=cluster_try_0, color=snow4, style=dashed, label="except ValueError"];
  transform_data -> router_data_pipeline_line_9_seq [ltail=cluster_try_0, color=snow4, style=dashed, label="except TypeError"];
}