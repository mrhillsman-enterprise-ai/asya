digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_ingester [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_ingester(p)</i></td></tr><tr><td bgcolor="white" align="left">p['candidates'] = retrieve(p['query']…top_k', 10))</td></tr></table>>];
  end_ingester [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_ingester(p)</i></td></tr></table>>];

  start_ingester -> end_ingester;
}