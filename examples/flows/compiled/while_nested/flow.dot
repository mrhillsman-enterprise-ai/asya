digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_while_nested_flow [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_while_nested_flow(p)</i></td></tr></table>>];
  router_while_nested_flow_line_16_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_while_nested_flow_line_16_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['j'] += 1</td></tr></table>>];
  router_while_nested_flow_line_15_while_1 [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_while_nested_flow_line_15_while_1(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['j'] &lt; p['max_j']</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_while_nested_flow_line_14_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_while_nested_flow_line_14_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['j'] = 0</td></tr></table>>];
  router_while_nested_flow_line_12_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_while_nested_flow_line_12_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['i'] += 1</td></tr></table>>];
  router_while_nested_flow_line_11_while_0 [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_while_nested_flow_line_11_while_0(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['i'] &lt; p['max_i']</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_while_nested_flow_line_10_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_while_nested_flow_line_10_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['i'] = 0</td></tr></table>>];
  end_while_nested_flow [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_while_nested_flow(p)</i></td></tr></table>>];
  handler_finalize [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_finalize(p)</i></td></tr></table>>];
  handler_init [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_init(p)</i></td></tr></table>>];
  handler_inner [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_inner(p)</i></td></tr></table>>];
  handler_outer [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_outer(p)</i></td></tr></table>>];
  handler_outer_end [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_outer_end(p)</i></td></tr></table>>];

  handler_finalize -> end_while_nested_flow;
  handler_init -> router_while_nested_flow_line_10_seq;
  handler_inner -> router_while_nested_flow_line_15_while_1 [constraint=false];
  handler_outer -> router_while_nested_flow_line_14_seq;
  handler_outer_end -> router_while_nested_flow_line_11_while_0 [constraint=false];
  router_while_nested_flow_line_10_seq -> router_while_nested_flow_line_11_while_0;
  router_while_nested_flow_line_11_while_0 -> handler_finalize [label="F", color=indianred4];
  router_while_nested_flow_line_11_while_0 -> router_while_nested_flow_line_12_seq [label="T", color=darkseagreen4];
  router_while_nested_flow_line_12_seq -> handler_outer;
  router_while_nested_flow_line_14_seq -> router_while_nested_flow_line_15_while_1;
  router_while_nested_flow_line_15_while_1 -> handler_outer_end [label="F", color=indianred4];
  router_while_nested_flow_line_15_while_1 -> router_while_nested_flow_line_16_seq [label="T", color=darkseagreen4];
  router_while_nested_flow_line_16_seq -> handler_inner;
  start_while_nested_flow -> handler_init;
}