digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_if_empty_branches_flow [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_if_empty_branches_flow(p)</i></td></tr></table>>];
  router_if_empty_branches_flow_line_10_if [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_if_empty_branches_flow_line_10_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['skip_processing']</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  end_if_empty_branches_flow [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_if_empty_branches_flow(p)</i></td></tr></table>>];
  handler_finalize [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_finalize(p)</i></td></tr></table>>];
  handler_process [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_process(p)</i></td></tr></table>>];
  handler_setup [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_setup(p)</i></td></tr></table>>];

  handler_finalize -> end_if_empty_branches_flow;
  handler_process -> handler_finalize;
  handler_setup -> router_if_empty_branches_flow_line_10_if;
  router_if_empty_branches_flow_line_10_if -> handler_finalize [label="T", color=darkseagreen4];
  router_if_empty_branches_flow_line_10_if -> handler_process [label="F", color=indianred4];
  start_if_empty_branches_flow -> handler_setup;
}