digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_complex_combined_flow [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_complex_combined_flow(p)</i></td></tr></table>>];
  router_complex_combined_flow_line_25_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_complex_combined_flow_line_25_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['stop_early']</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>pass</b></font></td></tr></table></td></tr></table>>];
  router_complex_combined_flow_line_20_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_complex_combined_flow_line_20_if(p)</i></td></tr><tr><td bgcolor="white" align="left">p['i'] += 1</td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['skip_even'] and p['i'] % 2 == 0</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_complex_combined_flow_line_17_while_0 [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_complex_combined_flow_line_17_while…(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['i'] &lt; p['max_iterations']</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_complex_combined_flow_line_16_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_complex_combined_flow_line_16_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['i'] = 0</td></tr></table>>];
  router_complex_combined_flow_line_30_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_complex_combined_flow_line_30_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['type'] == 'B'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_complex_combined_flow_line_28_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_complex_combined_flow_line_28_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['type'] == 'A'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_complex_combined_flow_line_15_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_complex_combined_flow_line_15_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['needs_loop']</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_complex_combined_flow_line_11_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_complex_combined_flow_line_11_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> not p['valid']</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  end_complex_combined_flow [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_complex_combined_flow(p)</i></td></tr></table>>];
  handler_default [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_default(p)</i></td></tr></table>>];
  handler_error [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_error(p)</i></td></tr></table>>];
  handler_finalize [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_finalize(p)</i></td></tr></table>>];
  handler_init [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_init(p)</i></td></tr></table>>];
  handler_process [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_process(p)</i></td></tr></table>>];
  handler_type_a [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_type_a(p)</i></td></tr></table>>];
  handler_type_b [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_type_b(p)</i></td></tr></table>>];

  handler_default -> handler_finalize;
  handler_error -> end_complex_combined_flow;
  handler_finalize -> end_complex_combined_flow;
  handler_init -> router_complex_combined_flow_line_11_if;
  handler_process -> router_complex_combined_flow_line_25_if;
  handler_type_a -> handler_finalize;
  handler_type_b -> handler_finalize;
  router_complex_combined_flow_line_11_if -> handler_error [label="T", color=darkseagreen4];
  router_complex_combined_flow_line_11_if -> router_complex_combined_flow_line_15_if [label="F", color=indianred4];
  router_complex_combined_flow_line_15_if -> router_complex_combined_flow_line_16_seq [label="T", color=darkseagreen4];
  router_complex_combined_flow_line_15_if -> router_complex_combined_flow_line_28_if [label="F", color=indianred4];
  router_complex_combined_flow_line_16_seq -> router_complex_combined_flow_line_17_while_0;
  router_complex_combined_flow_line_17_while_0 -> handler_finalize [label="F", color=indianred4];
  router_complex_combined_flow_line_17_while_0 -> router_complex_combined_flow_line_20_if [label="T", color=darkseagreen4];
  router_complex_combined_flow_line_20_if -> handler_process [label="F", color=indianred4];
  router_complex_combined_flow_line_20_if -> router_complex_combined_flow_line_17_while_0 [label="T", color=darkseagreen4];
  router_complex_combined_flow_line_25_if -> handler_finalize [label="T", color=darkseagreen4];
  router_complex_combined_flow_line_25_if -> router_complex_combined_flow_line_17_while_0 [label="F", color=indianred4, constraint=false];
  router_complex_combined_flow_line_28_if -> handler_type_a [label="T", color=darkseagreen4];
  router_complex_combined_flow_line_28_if -> router_complex_combined_flow_line_30_if [label="F", color=indianred4];
  router_complex_combined_flow_line_30_if -> handler_default [label="F", color=indianred4];
  router_complex_combined_flow_line_30_if -> handler_type_b [label="T", color=darkseagreen4];
  start_complex_combined_flow -> handler_init;
}