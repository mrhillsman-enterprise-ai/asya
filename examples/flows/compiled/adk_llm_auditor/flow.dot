digraph flow {
  rankdir=TB;
  compound=true;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_llm_auditor [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await start_llm_auditor(state)</i></td></tr><tr><td bgcolor="white" align="left">state['iteration'] = 0</td></tr><tr><td bgcolor="white" align="left">state['status'] = 'started'</td></tr><tr><td bgcolor="white" align="left">state['partial'] = True</td></tr></table>>];
  router_llm_auditor_line_38_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_38_s…(state)</i></td></tr><tr><td bgcolor="white" align="left">state['status'] = 'no_claims'</td></tr></table>>];
  router_llm_auditor_line_86_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_86_s…(state)</i></td></tr><tr><td bgcolor="white" align="left">state['partial'] = False</td></tr></table>>];
  router_llm_auditor_line_62_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_62_s…(state)</i></td></tr><tr><td bgcolor="white" align="left">state['prev_score'] = state['aggregate_score']</td></tr></table>>];
  router_llm_auditor_line_67_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_67_s…(state)</i></td></tr><tr><td bgcolor="white" align="left">state['status'] = 'approved'</td></tr></table>>];
  router_llm_auditor_line_69_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_69_if(state)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> state['aggregate_score'] &gt;= 70</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_llm_auditor_line_80_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_80_s…(state)</i></td></tr><tr><td bgcolor="white" align="left">state['status'] = 'max_iterations'</td></tr></table>>];
  router_llm_auditor_line_83_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_83_s…(state)</i></td></tr><tr><td bgcolor="white" align="left">state['prev_score'] = state['aggregate_score']</td></tr></table>>];
  router_llm_auditor_line_79_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_79_if(state)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> state['iteration'] &gt;= state.get('max_…rations', 5)</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_llm_auditor_line_66_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_66_if(state)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> state['aggregate_score'] &gt;= 90</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_llm_auditor_line_61_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_61_if(state)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> state['aggregate_score'] &gt; state.get(…score'] &lt; 70</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  fanout_llm_auditor_line_52 [fillcolor="lightblue", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await fanout_llm_auditor_line_52(state)</i></td></tr><tr><td bgcolor="mediumpurple2" align="center"><b>[fan-out:literal]</b></td></tr></table>>];
  router_llm_auditor_line_43_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_43_s…(state)</i></td></tr><tr><td bgcolor="white" align="left">state['iteration'] += 1</td></tr></table>>];
  router_llm_auditor_line_42_loop_back_0 [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_42_l…(state)</i></td></tr></table>>];
  router_llm_auditor_line_37_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await router_llm_auditor_line_37_if(state)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> not state.get('claims')</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  end_llm_auditor [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await end_llm_auditor(state)</i></td></tr></table>>];
  accuracy_scorer [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await accuracy_scorer(state)</i></td></tr></table>>];
  adk_llm_auditor_QualityScorer_aggregate [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await QualityScorer.aggregate(state)</i></td></tr></table>>];
  completeness_scorer [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await completeness_scorer(state)</i></td></tr></table>>];
  critique [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await critique(state)</i></td></tr></table>>];
  deep_reviser [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await deep_reviser(state)</i></td></tr></table>>];
  extract_claims [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await extract_claims(state)</i></td></tr></table>>];
  fallback_generate [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await fallback_generate(state)</i></td></tr></table>>];
  fanin_llm_auditor_line_52 [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await fanin_llm_auditor_line_52(state)</i></td></tr><tr><td bgcolor="mediumpurple1" align="center"><b>[fan-in]</b></td></tr></table>>];
  finalize [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await finalize(state)</i></td></tr></table>>];
  reviser [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await reviser(state)</i></td></tr></table>>];
  subgraph cluster_try_0 {
    style=dashed;
    color="snow4";
    fontname="Courier";
    fontsize=10;
    label="try";
    llm_generate [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = await llm_generate(state)</i></td></tr></table>>];
  }

  accuracy_scorer -> fanin_llm_auditor_line_52 [color=slateblue4, style=dashed];
  adk_llm_auditor_QualityScorer_aggregate -> router_llm_auditor_line_61_if;
  completeness_scorer -> fanin_llm_auditor_line_52 [color=slateblue4, style=dashed];
  critique -> deep_reviser;
  critique -> reviser;
  deep_reviser -> router_llm_auditor_line_79_if;
  extract_claims -> router_llm_auditor_line_37_if;
  fallback_generate -> fanout_llm_auditor_line_52;
  fanin_llm_auditor_line_52 -> adk_llm_auditor_QualityScorer_aggregate;
  fanout_llm_auditor_line_52 -> accuracy_scorer [color=mediumpurple4, label="slice 1", style=bold];
  fanout_llm_auditor_line_52 -> completeness_scorer [color=mediumpurple4, label="slice 2", style=bold];
  fanout_llm_auditor_line_52 -> fanin_llm_auditor_line_52 [color=mediumpurple4, label="slice 0\n(parent)", style=dashed];
  finalize -> end_llm_auditor;
  llm_generate -> fallback_generate [ltail=cluster_try_0, color=snow4, style=dashed, label="except", constraint=false];
  llm_generate -> fanout_llm_auditor_line_52;
  reviser -> router_llm_auditor_line_79_if;
  router_llm_auditor_line_37_if -> router_llm_auditor_line_38_seq [label="T", color=darkseagreen4];
  router_llm_auditor_line_37_if -> router_llm_auditor_line_42_loop_back_0 [label="F", color=indianred4];
  router_llm_auditor_line_38_seq -> end_llm_auditor;
  router_llm_auditor_line_42_loop_back_0 -> router_llm_auditor_line_43_seq [constraint=false];
  router_llm_auditor_line_43_seq -> llm_generate;
  router_llm_auditor_line_61_if -> router_llm_auditor_line_62_seq [label="T", color=darkseagreen4];
  router_llm_auditor_line_61_if -> router_llm_auditor_line_66_if [label="F", color=indianred4];
  router_llm_auditor_line_62_seq -> router_llm_auditor_line_42_loop_back_0;
  router_llm_auditor_line_66_if -> router_llm_auditor_line_67_seq [label="T", color=darkseagreen4];
  router_llm_auditor_line_66_if -> router_llm_auditor_line_69_if [label="F", color=indianred4];
  router_llm_auditor_line_67_seq -> end_llm_auditor;
  router_llm_auditor_line_69_if -> critique [label="F", color=indianred4];
  router_llm_auditor_line_69_if -> critique [label="T", color=darkseagreen4];
  router_llm_auditor_line_79_if -> router_llm_auditor_line_80_seq [label="T", color=darkseagreen4];
  router_llm_auditor_line_79_if -> router_llm_auditor_line_83_seq [label="F", color=indianred4];
  router_llm_auditor_line_80_seq -> router_llm_auditor_line_86_seq;
  router_llm_auditor_line_83_seq -> router_llm_auditor_line_42_loop_back_0;
  router_llm_auditor_line_86_seq -> finalize;
  start_llm_auditor -> extract_claims;
}