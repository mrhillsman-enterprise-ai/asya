digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_research_flow [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = start_research_flow(state)</i></td></tr></table>>];
  fanout_research_flow_line_11 [fillcolor="lightblue", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = fanout_research_flow_line_11(state)</i></td></tr><tr><td bgcolor="mediumpurple2" align="center"><b>[fan-out:comprehension]</b></td></tr><tr><td bgcolor="mediumpurple3" align="left">for t in state['topics']</td></tr></table>>];
  end_research_flow [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = end_research_flow(state)</i></td></tr></table>>];
  fanin_research_flow_line_11 [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = fanin_research_flow_line_11(state)</i></td></tr><tr><td bgcolor="mediumpurple1" align="center"><b>[fan-in]</b></td></tr></table>>];
  post_processor [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = post_processor(state)</i></td></tr></table>>];
  preprocessor [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = preprocessor(state)</i></td></tr></table>>];
  research_agent [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>state = research_agent(state)</i></td></tr></table>>];

  fanin_research_flow_line_11 -> post_processor;
  fanout_research_flow_line_11 -> fanin_research_flow_line_11 [color=mediumpurple4, label="slice 0\n(parent)", style=dashed];
  fanout_research_flow_line_11 -> research_agent [color=mediumpurple4, label="slice 1..N\n(per t)", style=bold];
  post_processor -> end_research_flow;
  preprocessor -> fanout_research_flow_line_11;
  research_agent -> fanin_research_flow_line_11 [color=slateblue4, style=dashed];
  start_research_flow -> preprocessor;
}