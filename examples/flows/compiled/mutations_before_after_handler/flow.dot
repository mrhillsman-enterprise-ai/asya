digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_mutations_before_after_handler_flow [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_mutations_before_after_handler_flow(p)</i></td></tr><tr><td bgcolor="white" align="left">p['step'] = 1</td></tr></table>>];
  router_mutations_before_after_handler_flow_line_13_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_mutations_before_after_handler_flow…(p)</i></td></tr><tr><td bgcolor="white" align="left">p['step'] = 3</td></tr></table>>];
  router_mutations_before_after_handler_flow_line_11_seq [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_mutations_before_after_handler_flow…(p)</i></td></tr><tr><td bgcolor="white" align="left">p['step'] = 2</td></tr></table>>];
  end_mutations_before_after_handler_flow [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_mutations_before_after_handler_flow(p)</i></td></tr></table>>];
  handler_a [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_a(p)</i></td></tr></table>>];
  handler_b [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_b(p)</i></td></tr></table>>];

  handler_a -> router_mutations_before_after_handler_flow_line_11_seq;
  handler_b -> router_mutations_before_after_handler_flow_line_13_seq;
  router_mutations_before_after_handler_flow_line_11_seq -> handler_b;
  router_mutations_before_after_handler_flow_line_13_seq -> end_mutations_before_after_handler_flow;
  start_mutations_before_after_handler_flow -> handler_a;
}