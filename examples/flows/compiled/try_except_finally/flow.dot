digraph flow {
  rankdir=TB;
  compound=true;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_resource_pipeline [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_resource_pipeline(p)</i></td></tr></table>>];
  router_resource_pipeline_line_7_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_resource_pipeline_line_7_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['status'] = 'failed'</td></tr></table>>];
  router_resource_pipeline_line_2_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_resource_pipeline_line_2_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['status'] = 'started'</td></tr></table>>];
  end_resource_pipeline [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_resource_pipeline(p)</i></td></tr></table>>];
  finalize [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = finalize(p)</i></td></tr></table>>];
  handle_failure [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handle_failure(p)</i></td></tr></table>>];
  subgraph cluster_try_0 {
    style=dashed;
    color="snow4";
    fontname="Courier";
    fontsize=10;
    label="try";
    acquire_resource [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = acquire_resource(p)</i></td></tr></table>>];
    process_with_resource [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = process_with_resource(p)</i></td></tr></table>>];
  }
  subgraph cluster_finally_0 {
    style=dashed;
    color="gray50";
    fontname="Courier";
    fontsize=10;
    label="finally";
    release_resource [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = release_resource(p)</i></td></tr></table>>];
  }

  acquire_resource -> process_with_resource;
  finalize -> end_resource_pipeline;
  handle_failure -> release_resource;
  process_with_resource -> release_resource;
  process_with_resource -> router_resource_pipeline_line_7_seq [ltail=cluster_try_0, color=snow4, style=dashed, label="except RuntimeError"];
  release_resource -> finalize;
  router_resource_pipeline_line_2_seq -> acquire_resource;
  router_resource_pipeline_line_7_seq -> handle_failure;
  start_resource_pipeline -> router_resource_pipeline_line_2_seq;
}