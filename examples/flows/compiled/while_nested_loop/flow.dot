digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_nested_loop_flow [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_nested_loop_flow(p)</i></td></tr></table>>];
  router_nested_loop_flow_line_16_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_nested_loop_flow_line_16_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['j'] += 1</td></tr></table>>];
  router_nested_loop_flow_line_15_loop_back_1 [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_nested_loop_flow_line_15_loop_back_1(p)</i></td></tr></table>>];
  router_nested_loop_flow_line_15_while_1 [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_nested_loop_flow_line_15_while_1(p)</i></td></tr><tr><td bgcolor="white" align="left">p['i'] += 1</td></tr><tr><td bgcolor="white" align="left">p['j'] = 0</td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['j'] &lt; p['max_j']</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_nested_loop_flow_line_12_loop_back_0 [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_nested_loop_flow_line_12_loop_back_0(p)</i></td></tr></table>>];
  router_nested_loop_flow_line_12_while_0 [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_nested_loop_flow_line_12_while_0(p)</i></td></tr><tr><td bgcolor="white" align="left">p['i'] = 0</td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['i'] &lt; p['max_i']</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  end_nested_loop_flow [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_nested_loop_flow(p)</i></td></tr></table>>];
  finalize_loop_i [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = finalize_loop_i(p)</i></td></tr></table>>];
  finalize_loop_j [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = finalize_loop_j(p)</i></td></tr></table>>];
  initialize [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = initialize(p)</i></td></tr></table>>];
  process_item [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = process_item(p)</i></td></tr></table>>];

  finalize_loop_i -> end_nested_loop_flow;
  initialize -> router_nested_loop_flow_line_12_while_0;
  router_nested_loop_flow_line_12_loop_back_0 -> router_nested_loop_flow_line_12_while_0 [constraint=false];
  router_nested_loop_flow_line_12_while_0 -> finalize_loop_i [color=indianred4];
  router_nested_loop_flow_line_12_while_0 -> router_nested_loop_flow_line_15_while_1 [color=darkseagreen4];
  router_nested_loop_flow_line_15_loop_back_1 -> router_nested_loop_flow_line_15_while_1 [constraint=false];
  router_nested_loop_flow_line_15_while_1 -> finalize_loop_j [color=indianred4];
  router_nested_loop_flow_line_15_while_1 -> router_nested_loop_flow_line_16_seq [color=darkseagreen4];
  router_nested_loop_flow_line_16_seq -> process_item;
  router_nested_loop_flow_line_16_seq -> router_nested_loop_flow_line_15_loop_back_1;
  start_nested_loop_flow -> initialize;
}