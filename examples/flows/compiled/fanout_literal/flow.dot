digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_analysis_flow [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_analysis_flow(p)</i></td></tr></table>>];
  fanout_analysis_flow_line_10 [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = fanout_analysis_flow_line_10(p)</i></td></tr><tr><td bgcolor="mediumpurple2" align="center"><b>[fan-out:literal]</b></td></tr></table>>];
  end_analysis_flow [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_analysis_flow(p)</i></td></tr></table>>];
  entity_recognizer [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = entity_recognizer(p)</i></td></tr></table>>];
  fanin_analysis_flow_line_10 [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = fanin_analysis_flow_line_10(p)</i></td></tr><tr><td bgcolor="mediumpurple1" align="center"><b>[fan-in]</b></td></tr></table>>];
  merge_analysis [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = merge_analysis(p)</i></td></tr></table>>];
  sentiment_analyzer [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = sentiment_analyzer(p)</i></td></tr></table>>];
  topic_extractor [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = topic_extractor(p)</i></td></tr></table>>];

  entity_recognizer -> fanin_analysis_flow_line_10 [color=slateblue4, style=dashed];
  fanin_analysis_flow_line_10 -> merge_analysis;
  fanout_analysis_flow_line_10 -> entity_recognizer [color=mediumpurple4, label="slice 3", style=bold];
  fanout_analysis_flow_line_10 -> fanin_analysis_flow_line_10 [color=mediumpurple4, label="slice 0\n(parent)", style=dashed];
  fanout_analysis_flow_line_10 -> sentiment_analyzer [color=mediumpurple4, label="slice 1", style=bold];
  fanout_analysis_flow_line_10 -> topic_extractor [color=mediumpurple4, label="slice 2", style=bold];
  merge_analysis -> end_analysis_flow;
  sentiment_analyzer -> fanin_analysis_flow_line_10 [color=slateblue4, style=dashed];
  start_analysis_flow -> fanout_analysis_flow_line_10;
  topic_extractor -> fanin_analysis_flow_line_10 [color=slateblue4, style=dashed];
}