digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_if_mutations_in_branches_flow [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_if_mutations_in_branches_flow(p)</i></td></tr></table>>];
  router_if_mutations_in_branches_flow_line_11_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_if_mutations_in_branches_flow_line_…(p)</i></td></tr><tr><td bgcolor="white" align="left">p['branch'] = 'A'</td></tr><tr><td bgcolor="white" align="left">p['value'] = 100</td></tr></table>>];
  router_if_mutations_in_branches_flow_line_16_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_if_mutations_in_branches_flow_line_…(p)</i></td></tr><tr><td bgcolor="white" align="left">p['branch'] = 'B'</td></tr><tr><td bgcolor="white" align="left">p['value'] = 200</td></tr></table>>];
  router_if_mutations_in_branches_flow_line_10_if [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_if_mutations_in_branches_flow_line_…(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['type'] == 'A'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  end_if_mutations_in_branches_flow [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_if_mutations_in_branches_flow(p)</i></td></tr></table>>];
  handler_finalize [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_finalize(p)</i></td></tr></table>>];
  handler_setup [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_setup(p)</i></td></tr></table>>];
  handler_type_a [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_type_a(p)</i></td></tr></table>>];
  handler_type_b [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = handler_type_b(p)</i></td></tr></table>>];

  handler_finalize -> end_if_mutations_in_branches_flow;
  handler_setup -> router_if_mutations_in_branches_flow_line_10_if;
  handler_type_a -> handler_finalize;
  handler_type_b -> router_if_mutations_in_branches_flow_line_16_seq;
  router_if_mutations_in_branches_flow_line_10_if -> handler_type_b [color=indianred4];
  router_if_mutations_in_branches_flow_line_10_if -> router_if_mutations_in_branches_flow_line_11_seq [color=darkseagreen4];
  router_if_mutations_in_branches_flow_line_11_seq -> handler_type_a;
  router_if_mutations_in_branches_flow_line_16_seq -> handler_finalize;
  start_if_mutations_in_branches_flow -> handler_setup;
}