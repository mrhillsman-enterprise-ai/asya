digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_adaptive_flow [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_adaptive_flow(p)</i></td></tr></table>>];
  fanout_adaptive_flow_line_13 [fillcolor="lightblue", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = fanout_adaptive_flow_line_13(p)</i></td></tr><tr><td bgcolor="mediumpurple2" align="center"><b>[fan-out:literal]</b></td></tr></table>>];
  router_adaptive_flow_line_12_if [fillcolor="wheat", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_adaptive_flow_line_12_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['parallel']</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  end_adaptive_flow [fillcolor="lightgreen", group="main", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_adaptive_flow(p)</i></td></tr></table>>];
  classifier [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = classifier(p)</i></td></tr></table>>];
  deep_analyzer [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = deep_analyzer(p)</i></td></tr></table>>];
  fanin_adaptive_flow_line_13 [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = fanin_adaptive_flow_line_13(p)</i></td></tr><tr><td bgcolor="mediumpurple1" align="center"><b>[fan-in]</b></td></tr></table>>];
  fast_analyzer [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = fast_analyzer(p)</i></td></tr></table>>];
  formatter [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = formatter(p)</i></td></tr></table>>];
  sequential_analyzer [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = sequential_analyzer(p)</i></td></tr></table>>];

  classifier -> router_adaptive_flow_line_12_if;
  deep_analyzer -> fanin_adaptive_flow_line_13 [color=slateblue4, style=dashed];
  fanin_adaptive_flow_line_13 -> formatter;
  fanout_adaptive_flow_line_13 -> deep_analyzer [color=mediumpurple4, label="slice 2", style=bold];
  fanout_adaptive_flow_line_13 -> fanin_adaptive_flow_line_13 [color=mediumpurple4, label="slice 0\n(parent)", style=dashed];
  fanout_adaptive_flow_line_13 -> fast_analyzer [color=mediumpurple4, label="slice 1", style=bold];
  fast_analyzer -> fanin_adaptive_flow_line_13 [color=slateblue4, style=dashed];
  formatter -> end_adaptive_flow;
  router_adaptive_flow_line_12_if -> fanout_adaptive_flow_line_13 [label="T", color=darkseagreen4];
  router_adaptive_flow_line_12_if -> sequential_analyzer [label="F", color=indianred4];
  sequential_analyzer -> formatter;
  start_adaptive_flow -> classifier;
}