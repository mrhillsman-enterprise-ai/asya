helmDefaults:
  wait: true
  timeout: 1200
  createNamespace: true
  atomic: false

environments:
  rabbitmq-minio:
    values:
      - values.yaml
      - ../profiles/rabbitmq-minio.yaml
  sqs-s3:
    values:
      - values.yaml
      - ../profiles/sqs-s3.yaml
  pubsub-gcs:
    values:
      - values.yaml
      - ../profiles/pubsub-gcs.yaml

---

repositories:
  - name: kedacore
    url: https://kedacore.github.io/charts
  - name: crossplane-stable
    url: https://charts.crossplane.io/stable
  # Disabled: prometheus and grafana not used in e2e
  # - name: prometheus-community
  #   url: https://prometheus-community.github.io/helm-charts
  # - name: grafana
  #   url: https://grafana.github.io/helm-charts

releases:
  - name: keda
    namespace: {{ .Values.namespace | default "asya-e2e" }}
    chart: kedacore/keda
    labels:
      layer: infra
    {{- if hasKey .Values "keda" }}
    values:
      - {{- .Values.keda | toYaml | nindent 8 }}
    {{- end }}
    hooks:
      - events: ["presync"]
        command: "sh"
        args: ["-c", "echo '[.] Deploying KEDA...' && date +%s > /tmp/helm-keda-start"]
      - events: ["postsync"]
        command: "sh"
        args: ["-c", "echo \"[+] KEDA deployed in $(($(date +%s) - $(cat /tmp/helm-keda-start)))s\""]

# Disabled: prometheus and grafana are not tested in e2e
  # - name: prometheus
  #   namespace: {{ .Values.namespace | default "asya-e2e" }}
  #   chart: prometheus-community/prometheus
  #   labels:
  #     layer: infra

  # - name: grafana
  #   namespace: {{ .Values.namespace | default "asya-e2e" }}
  #   chart: grafana/grafana
  #   labels:
  #     layer: infra

  - name: postgres
    namespace: {{ .Values.namespace | default "asya-e2e" }}
    chart: ./postgres
    labels:
      layer: infra
    hooks:
      - events: ["presync"]
        command: "sh"
        args: ["-c", "echo '[.] Deploying PostgreSQL...' && date +%s > /tmp/helm-postgres-start"]
      - events: ["postsync"]
        command: "sh"
        args: ["-c", "echo \"[+] PostgreSQL deployed in $(($(date +%s) - $(cat /tmp/helm-postgres-start)))s\""]

  - name: s3
    namespace: asya-system
    chart: ./s3
    condition: storage.s3.enabled
    values:
      - enabled: {{ .Values.storage.s3.enabled | default false }}
        region: us-east-1
        {{- if and .Values.storage.s3.enabled .Values.actors.storage }}
        buckets:
          {{- if hasKey .Values.actors.storage "resultsBucket" }}
          - name: {{ .Values.actors.storage.resultsBucket }}
          {{- end }}
          {{- if hasKey .Values.actors.storage "errorsBucket" }}
          - name: {{ .Values.actors.storage.errorsBucket }}
          {{- end }}
          {{- if and (not (hasKey .Values.actors.storage "resultsBucket")) (not (hasKey .Values.actors.storage "errorsBucket")) (hasKey .Values.actors.storage "bucket") }}
          - name: {{ .Values.actors.storage.bucket }}
          {{- end }}
        {{- end }}
    labels:
      layer: infra
    hooks:
      - events: ["presync"]
        command: "sh"
        args: ["-c", "echo '[.] Deploying S3 (LocalStack)...' && date +%s > /tmp/helm-s3-start"]
      - events: ["postsync"]
        command: "sh"
        args: ["-c", "echo \"[+] S3 (LocalStack) deployed in $(($(date +%s) - $(cat /tmp/helm-s3-start)))s\""]

  - name: sqs
    namespace: asya-system
    chart: ./sqs
    condition: transport.sqs.enabled
    values:
      - enabled: {{ .Values.transport.sqs.enabled | default false }}
        region: us-east-1
    labels:
      layer: infra
    hooks:
      - events: ["presync"]
        command: "sh"
        args: ["-c", "echo '[.] Deploying SQS (LocalStack)...' && date +%s > /tmp/helm-sqs-start"]
      - events: ["postsync"]
        command: "sh"
        args: ["-c", "echo \"[+] SQS (LocalStack) deployed in $(($(date +%s) - $(cat /tmp/helm-sqs-start)))s\""]

  - name: rabbitmq
    namespace: {{ .Values.namespace | default "asya-e2e" }}
    chart: ./rabbitmq
    condition: transport.rabbitmq.enabled
    labels:
      layer: infra
    hooks:
      - events: ["presync"]
        command: "sh"
        args: ["-c", "echo '[.] Deploying RabbitMQ...' && date +%s > /tmp/helm-rabbitmq-start"]
      - events: ["postsync"]
        command: "sh"
        args: ["-c", "echo \"[+] RabbitMQ deployed in $(($(date +%s) - $(cat /tmp/helm-rabbitmq-start)))s\""]

  - name: minio
    namespace: {{ .Values.namespace | default "asya-e2e" }}
    chart: ./minio
    condition: storage.minio.enabled
    labels:
      layer: infra
    hooks:
      - events: ["presync"]
        command: "sh"
        args: ["-c", "echo '[.] Deploying MinIO...' && date +%s > /tmp/helm-minio-start"]
      - events: ["postsync"]
        command: "sh"
        args: ["-c", "echo \"[+] MinIO deployed in $(($(date +%s) - $(cat /tmp/helm-minio-start)))s\""]

  - name: pubsub
    namespace: asya-system
    chart: ./pubsub
    condition: transport.pubsub.enabled
    values:
      - enabled: {{ .Values.transport.pubsub.enabled | default false }}
        projectId: test-project
    labels:
      layer: infra
    hooks:
      - events: ["presync"]
        command: "sh"
        args: ["-c", "echo '[.] Deploying Pub/Sub (emulator)...' && date +%s > /tmp/helm-pubsub-start"]
      - events: ["postsync"]
        command: "sh"
        args: ["-c", "echo \"[+] Pub/Sub (emulator) deployed in $(($(date +%s) - $(cat /tmp/helm-pubsub-start)))s\""]

  - name: gcs
    namespace: asya-system
    chart: ./gcs
    condition: storage.gcs.enabled
    values:
      - enabled: {{ .Values.storage.gcs.enabled | default false }}
        {{- if and (.Values.storage.gcs.enabled) (.Values.actors).storage }}
        buckets:
          {{- with .Values.actors.storage.resultsBucket }}
          - {{ . }}
          {{- end }}
          {{- with .Values.actors.storage.errorsBucket }}
          - {{ . }}
          {{- end }}
        {{- end }}
    labels:
      layer: infra
    hooks:
      - events: ["presync"]
        command: "sh"
        args: ["-c", "echo '[.] Deploying GCS (emulator)...' && date +%s > /tmp/helm-gcs-start"]
      - events: ["postsync"]
        command: "sh"
        args: ["-c", "echo \"[+] GCS (emulator) deployed in $(($(date +%s) - $(cat /tmp/helm-gcs-start)))s\""]

  - name: jwks-server
    namespace: {{ .Values.namespace | default "asya-e2e" }}
    chart: ./jwks-server
    labels:
      layer: infra
    hooks:
      - events: ["presync"]
        command: "sh"
        args: ["-c", "echo '[.] Deploying JWKS server...' && date +%s > /tmp/helm-jwks-start"]
      - events: ["postsync"]
        command: "sh"
        args: ["-c", "echo \"[+] JWKS server deployed in $(($(date +%s) - $(cat /tmp/helm-jwks-start)))s\""]

  - name: asya-crossplane
    namespace: asya-system
    chart: ../../../deploy/helm-charts/asya-crossplane
    needs:
      {{- if .Values.transport.sqs.enabled }}
      - sqs
      {{- end }}
      {{- if .Values.storage.s3.enabled }}
      - s3
      {{- end }}
      {{- if .Values.transport.rabbitmq.enabled }}
      - rabbitmq
      {{- end }}
      {{- if .Values.storage.minio.enabled }}
      - minio
      {{- end }}
      {{- if .Values.transport.pubsub.enabled }}
      - pubsub
      {{- end }}
      {{- if .Values.storage.gcs.enabled }}
      - gcs
      {{- end }}
    values:
      - {{- .Values.crossplane | toYaml | nindent 8 }}
    labels:
      layer: infra
    hooks:
      - events: ["presync"]
        command: "sh"
        args: ["-c", "echo '[.] Deploying asya-crossplane...' && date +%s > /tmp/helm-crossplane-start"]
      - events: ["postsync"]
        command: "sh"
        args: ["-c", "echo \"[+] asya-crossplane deployed in $(($(date +%s) - $(cat /tmp/helm-crossplane-start)))s\""]

  - name: asya-injector
    namespace: asya-system
    chart: ../../../deploy/helm-charts/asya-injector
    needs:
      - asya-crossplane
    values:
      - {{- .Values.injector | toYaml | nindent 8 }}
    labels:
      layer: infra
    hooks:
      - events: ["presync"]
        command: "sh"
        args: ["-c", "echo '[.] Deploying asya-injector...' && date +%s > /tmp/helm-injector-start"]
      - events: ["postsync"]
        command: "sh"
        args: ["-c", "echo \"[+] asya-injector deployed in $(($(date +%s) - $(cat /tmp/helm-injector-start)))s\""]

  - name: asya-gateway
    namespace: {{ .Values.namespace | default "asya-e2e" }}
    chart: ../../../deploy/helm-charts/asya-gateway
    needs:
      - postgres
    set:
      - name: postgresql.enabled
        value: false
      - name: externalDatabase.host
        value: asya-gateway-postgresql.{{ .Values.namespace | default "asya-e2e" }}.svc.cluster.local
      - name: externalDatabase.port
        value: 5432
      - name: externalDatabase.database
        value: asya_gateway
      - name: externalDatabase.username
        value: asya
      - name: externalDatabase.password
        value: asya-db-password
    values:
      - {{- .Values.gateway | toYaml | nindent 8 }}
    labels:
      layer: infra

  # System actors (crew) - using asya-crew chart (deployed before test-actors)
  - name: asya-crew
    namespace: {{ .Values.namespace | default "asya-e2e" }}
    chart: ../../../deploy/helm-charts/asya-crew
    values:
      - {{- .Values.crew | toYaml | nindent 8 }}
    labels:
      layer: app

  # Test actors - deployed using asya-test-actors chart
  - name: test-actors
    namespace: {{ .Values.namespace | default "asya-e2e" }}
    chart: ./asya-test-actors
    needs:
      - asya-crew
    values:
      - namespace: {{ .Values.actors.namespace | default "asya-e2e" }}
        transport: {{ .Values.actors.transport | default "rabbitmq" }}
        workload:
          image: ghcr.io/deliveryhero/asya-testing:latest
          imagePullPolicy: Never
    labels:
      layer: app

  # Flow test actors - deployed using asya-test-flows chart
  - name: test-flows
    namespace: {{ .Values.namespace | default "asya-e2e" }}
    chart: ./asya-test-flows
    needs:
      - asya-crew
    values:
      - transport: {{ .Values.actors.transport | default "rabbitmq" }}
        workload:
          image: ghcr.io/deliveryhero/asya-testing:latest
          imagePullPolicy: Never
        crewImage: ghcr.io/deliveryhero/asya-crew:latest
        stateProxy:
          backend: {{ .Values.actors.storage.type | default "s3" }}
          config:
            bucket: {{ .Values.actors.storage.bucket | default "asya-results" }}
            {{- if eq (.Values.actors.storage.type | default "s3") "s3" }}
            endpoint: {{ .Values.actors.storage.endpoint | default "" }}
            region: {{ .Values.actors.storage.region | default "us-east-1" }}
            accessKey: {{ .Values.actors.storage.accessKey | default "" }}
            secretKey: {{ .Values.actors.storage.secretKey | default "" }}
            {{- else if eq .Values.actors.storage.type "gcs" }}
            project: {{ .Values.actors.storage.project | default "" }}
            emulatorHost: {{ .Values.actors.storage.emulatorHost | default "" }}
            {{- end }}
    labels:
      layer: app
