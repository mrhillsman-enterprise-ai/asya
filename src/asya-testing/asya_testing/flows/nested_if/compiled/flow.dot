digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_test_nested_flow [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_test_nested_flow(p)</i></td></tr></table>>];
  router_test_nested_flow_line_7_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_test_nested_flow_line_7_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['route'] = 'A-X'</td></tr></table>>];
  router_test_nested_flow_line_10_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_test_nested_flow_line_10_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['route'] = 'A-Y'</td></tr></table>>];
  router_test_nested_flow_line_6_if [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_test_nested_flow_line_6_if(p)</i></td></tr><tr><td bgcolor="white" align="left">p['path'] = 'A'</td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['level2'] == 'X'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_test_nested_flow_line_15_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_test_nested_flow_line_15_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['route'] = 'B-X'</td></tr></table>>];
  router_test_nested_flow_line_18_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_test_nested_flow_line_18_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['route'] = 'B-Y'</td></tr></table>>];
  router_test_nested_flow_line_14_if [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_test_nested_flow_line_14_if(p)</i></td></tr><tr><td bgcolor="white" align="left">p['path'] = 'B'</td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['level2'] == 'X'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_test_nested_flow_line_4_if [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_test_nested_flow_line_4_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['level1'] == 'A'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  end_test_nested_flow [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_test_nested_flow(p)</i></td></tr></table>>];
  finalize_result [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = finalize_result(p)</i></td></tr></table>>];
  route_a_x [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = route_a_x(p)</i></td></tr></table>>];
  route_a_y [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = route_a_y(p)</i></td></tr></table>>];
  route_b_x [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = route_b_x(p)</i></td></tr></table>>];
  route_b_y [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = route_b_y(p)</i></td></tr></table>>];
  validate_input [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = validate_input(p)</i></td></tr></table>>];

  finalize_result -> end_test_nested_flow;
  route_a_x -> finalize_result;
  route_a_y -> finalize_result;
  route_b_x -> finalize_result;
  route_b_y -> finalize_result;
  router_test_nested_flow_line_10_seq -> route_a_y;
  router_test_nested_flow_line_14_if -> router_test_nested_flow_line_15_seq [color=darkseagreen4];
  router_test_nested_flow_line_14_if -> router_test_nested_flow_line_18_seq [color=indianred4];
  router_test_nested_flow_line_15_seq -> route_b_x;
  router_test_nested_flow_line_18_seq -> route_b_y;
  router_test_nested_flow_line_4_if -> router_test_nested_flow_line_14_if [color=indianred4];
  router_test_nested_flow_line_4_if -> router_test_nested_flow_line_6_if [color=darkseagreen4];
  router_test_nested_flow_line_6_if -> router_test_nested_flow_line_10_seq [color=indianred4];
  router_test_nested_flow_line_6_if -> router_test_nested_flow_line_7_seq [color=darkseagreen4];
  router_test_nested_flow_line_7_seq -> route_a_x;
  start_test_nested_flow -> validate_input;
  validate_input -> router_test_nested_flow_line_4_if;
}