.PHONY: test-unit cov-unit clean
MAKEFLAGS += --no-print-directory

test-unit:
	@echo "[+] Success: UI unit tests (no tests yet)"

cov-unit:
	@echo "UI (TypeScript) coverage: N/A (no tests yet)"

clean:
	rm -rf node_modules/
	rm -rf packages/*/node_modules/
	rm -rf packages/*/dist/
	@echo "[+] Clean complete"
