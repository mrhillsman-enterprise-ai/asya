digraph flow {
  rankdir=TB;
  graph [fontname="Courier", fontsize=10];
  node [fontname="Courier", fontsize=10, shape=box, style="filled,rounded", margin="0.2"];
  edge [fontname="Courier", fontsize=10];

  start_text_analysis_flow [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = start_text_analysis_flow(p)</i></td></tr></table>>];
  router_text_analysis_flow_line_14_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_text_analysis_flow_line_14_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['sentiment'] = 'neutral'</td></tr></table>>];
  router_text_analysis_flow_line_11_if [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_text_analysis_flow_line_11_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['language'] == 'es'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  router_text_analysis_flow_line_18_seq [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_text_analysis_flow_line_18_seq(p)</i></td></tr><tr><td bgcolor="white" align="left">p['extracted'] = True</td></tr></table>>];
  router_text_analysis_flow_line_9_if [fillcolor="wheat", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = router_text_analysis_flow_line_9_if(p)</i></td></tr><tr><td bgcolor="lightyellow"><b>if</b> p['language'] == 'en'</td></tr><tr><td><table border="0" cellspacing="0" cellpadding="4"><tr><td bgcolor="darkseagreen4"><font color="white"><b>TRUE</b></font></td><td bgcolor="indianred4"><font color="white"><b>FALSE</b></font></td></tr></table></td></tr></table>>];
  end_text_analysis_flow [fillcolor="lightgreen", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = end_text_analysis_flow(p)</i></td></tr></table>>];
  clean_text [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = clean_text(p)</i></td></tr></table>>];
  english_sentiment [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = english_sentiment(p)</i></td></tr></table>>];
  extract_entities [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = extract_entities(p)</i></td></tr></table>>];
  spanish_sentiment [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = spanish_sentiment(p)</i></td></tr></table>>];
  tokenize [fillcolor="lightblue", label=<<table border="0" cellspacing="0" cellpadding="6" cellborder="1"><tr><td bgcolor="white" align="center"><i>p = tokenize(p)</i></td></tr></table>>];

  clean_text -> tokenize;
  english_sentiment -> extract_entities;
  extract_entities -> router_text_analysis_flow_line_18_seq;
  router_text_analysis_flow_line_11_if -> router_text_analysis_flow_line_14_seq [color=indianred4];
  router_text_analysis_flow_line_11_if -> spanish_sentiment [color=darkseagreen4];
  router_text_analysis_flow_line_14_seq -> extract_entities;
  router_text_analysis_flow_line_18_seq -> end_text_analysis_flow;
  router_text_analysis_flow_line_9_if -> english_sentiment [color=darkseagreen4];
  router_text_analysis_flow_line_9_if -> router_text_analysis_flow_line_11_if [color=indianred4];
  spanish_sentiment -> extract_entities;
  start_text_analysis_flow -> clean_text;
  tokenize -> router_text_analysis_flow_line_9_if;
}